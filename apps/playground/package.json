{
  "name": "@vibecook/spaghetti-playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "predev": "electron-rebuild -f -w better-sqlite3",
    "prestart": "electron-rebuild -f -w better-sqlite3",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "clean": "rm -rf out",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "pnpm -w rebuild better-sqlite3"
  },
  "dependencies": {
    "@vibecook/spaghetti-sdk": "workspace:*",
    "better-sqlite3": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.0.0",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
