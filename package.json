{
  "name": "spaghetti",
  "version": "0.5.5",
  "private": true,
  "type": "module",
  "description": "Untangle your Claude Code history — browse, search, and analyze all your conversations from the terminal",
  "license": "MIT",
  "author": "James Yong",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesyong-42/spaghetti.git"
  },
  "homepage": "https://github.com/jamesyong-42/spaghetti",
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "conversation",
    "history",
    "search",
    "sqlite"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "typecheck": "pnpm -r typecheck",
    "validate": "bash scripts/validate-all.sh",
    "test:packages": "pnpm --filter @vibecook/spaghetti-sdk test && pnpm --filter @vibecook/spaghetti test",
    "test:ingest-diff": "tsx scripts/ingest-diff.ts",
    "bench:ingest": "tsx scripts/bench-ingest.ts",
    "test": "pnpm typecheck && pnpm validate && pnpm test:packages",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}' 'apps/*/src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}' 'apps/*/src/**/*.{ts,tsx}'",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx}' 'apps/*/src/**/*.{ts,tsx}'"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "electron"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@msgpack/msgpack": "^3.1.3",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.57.2"
  }
}
