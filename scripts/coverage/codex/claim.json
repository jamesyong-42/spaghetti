{
  "schemaVersion": 1,
  "agentId": "codex",
  "updated": "2026-07-13",
  "rootDefault": "~/.codex",
  "description": "Honest coverage claim for OpenAI Codex CLI. v1 is a thin multi-agent slice: projects/sessions/chat messages/search/tokens/live rollouts. Most rollout record kinds and side artifacts are deliberately not productized yet — but they must stay documented.",
  "engines": {
    "ts": "packages/sdk sources/codex + CodexLifecycleOwner (only engine today)",
    "rs": "not implemented for Codex"
  },
  "surfaces": [
    {
      "id": "rollout.file",
      "status": "ingested",
      "match": { "bucket": "rollout.file" },
      "engines": { "ts": true, "rs": false },
      "product": ["projects", "sessions"],
      "notes": "sessions/**/rollout-*.jsonl discovered by CodexReader."
    },
    {
      "id": "rollout.record_type.response_item/message",
      "status": "ingested",
      "match": { "recordType": "response_item/message" },
      "engines": { "ts": true, "rs": false },
      "product": ["messages", "search", "fts"],
      "notes": "Only chat turns written to messages (role→msgType, content text flatten)."
    },
    {
      "id": "rollout.record_type.event_msg/token_count",
      "status": "partial",
      "match": { "recordType": "event_msg/token_count" },
      "engines": { "ts": true, "rs": false },
      "product": ["tokens"],
      "notes": "Not stored as rows; last_token_usage attributed onto prior assistant; else tiktoken estimate."
    },
    {
      "id": "rollout.record_type.session_meta",
      "status": "partial",
      "match": { "recordType": "session_meta" },
      "engines": { "ts": true, "rs": false },
      "product": ["projects", "sessions"],
      "notes": "Peeked for cwd + session id; not stored as a message row."
    },
    {
      "id": "rollout.record_type.response_item/function_call",
      "status": "ignored",
      "match": { "recordType": "response_item/function_call" },
      "engines": { "ts": false, "rs": false },
      "notes": "Largest volume class on real installs. extract()→null. Candidate for tool timeline."
    },
    {
      "id": "rollout.record_type.response_item/function_call_output",
      "status": "ignored",
      "match": { "recordType": "response_item/function_call_output" },
