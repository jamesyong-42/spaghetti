{
  "name": "@vibecook/spaghetti",
  "version": "0.4.0",
  "type": "module",
  "bin": {
    "spaghetti": "./dist/bin.js",
    "spag": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "postbuild": "node -e \"try{require('fs').chmodSync('dist/bin.js',0o755)}catch{}\"",
    "test": "node --import tsx --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@vibecook/spaghetti-core": "workspace:*",
    "cli-truncate": "^4.0.0",
    "commander": "^13.1.0",
    "ink": "^6.8.0",
    "nanospinner": "^1.2.2",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "string-width": "^7.2.0",
    "ws": "^8.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesyong-42/spaghetti.git",
    "directory": "packages/cli"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
